ORCHESTRATOR_API_KEY=replace-with-a-long-random-token
WEB_SESSION_SECRET=replace-with-a-different-long-random-token
WEB_AUTH_USERNAME=admin
WEB_AUTH_PASSWORD=replace-with-a-long-random-password

# Optional Telegram bot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=
TELEGRAM_USER=admin
TELEGRAM_PERMISSION_MODE=bypassPermissions

